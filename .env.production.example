# Nirogidhara AI Command Center — production env (Hostinger VPS).
#
# Copy this file to `.env.production` on the VPS and fill in real values.
# **NEVER commit `.env.production`** — it is gitignored at the repo root.
#
# Compose loads this file via `--env-file .env.production`; every backend
# container also reads it through `env_file:` in `docker-compose.prod.yml`.
#
# Hard safety rules (Master Blueprint §26 / Phase 5A-1):
#   - Keep WHATSAPP_PROVIDER=mock until Meta WABA credentials are ready.
#   - Keep RAZORPAY_MODE=mock until Razorpay live keys + webhook are ready.
#   - Keep DELHIVERY_MODE=mock until production token confirmed.
#   - Keep VAPI_MODE=mock until Vapi live key confirmed.
#   - ALLOWED_HOSTS / CORS / CSRF must include ai.nirogidhara.com.
#   - DEBUG must be false in production.

# ===== Django core =====
DJANGO_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING
DJANGO_DEBUG=false
DJANGO_TIME_ZONE=Asia/Kolkata
DJANGO_ALLOWED_HOSTS=ai.nirogidhara.com,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://ai.nirogidhara.com
CSRF_TRUSTED_ORIGINS=https://ai.nirogidhara.com
JWT_SIGNING_KEY=CHANGE_ME_DIFFERENT_FROM_SECRET_KEY

# ===== Database (Postgres container) =====
POSTGRES_DB=nirogidhara
POSTGRES_USER=nirogidhara
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgres://nirogidhara:CHANGE_ME_STRONG_PASSWORD@postgres:5432/nirogidhara

# ===== Redis / Celery / Channels =====
# `redis` resolves to the sibling container in `nirogidhara_network`.
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_ALWAYS_EAGER=false
CHANNEL_LAYER_BACKEND=redis
CHANNEL_REDIS_URL=redis://redis:6379/2

# Daily AI briefing cadence (IST defaults from Phase 3C).
AI_DAILY_BRIEFING_MORNING_HOUR=9
AI_DAILY_BRIEFING_MORNING_MINUTE=0
AI_DAILY_BRIEFING_EVENING_HOUR=18
AI_DAILY_BRIEFING_EVENING_MINUTE=0
AI_TIMEZONE=Asia/Kolkata

# ===== AI providers =====
# Use `disabled` to short-circuit every LLM call (matches dev default).
# Switch to `openai` once OPENAI_API_KEY is filled in. The fallback chain
# walks left → right; ClaimVaultMissing refusals NEVER trigger a fallback.
AI_PROVIDER=disabled
AI_PROVIDER_FALLBACKS=openai,anthropic
AI_MODEL=gpt-5.1
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=2000
AI_REQUEST_TIMEOUT_SECONDS=30

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_ORG_ID=
OPENAI_FALLBACK_MODEL=gpt-5.1

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=claude-sonnet-4-6

GROK_API_KEY=
GROK_BASE_URL=
GROK_MODEL=

# Phase 3D — Sandbox boot-time default. The DB-backed SandboxState
# singleton is the live toggle; this var is the boot-time seed.
AI_SANDBOX_MODE=false

# ===== Razorpay (Phase 2B) =====
RAZORPAY_MODE=mock
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_CALLBACK_URL=https://ai.nirogidhara.com/api/webhooks/razorpay/

# ===== Delhivery (Phase 2C) =====
DELHIVERY_MODE=mock
DELHIVERY_API_BASE_URL=
DELHIVERY_API_TOKEN=
DELHIVERY_PICKUP_LOCATION=
DELHIVERY_RETURN_ADDRESS=
DELHIVERY_DEFAULT_PACKAGE_WEIGHT_GRAMS=500
DELHIVERY_WEBHOOK_SECRET=

# ===== Vapi (Phase 2D) =====
VAPI_MODE=mock
VAPI_API_BASE_URL=https://api.vapi.ai
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=
VAPI_WEBHOOK_SECRET=
VAPI_DEFAULT_LANGUAGE=hi-IN
VAPI_CALLBACK_URL=https://ai.nirogidhara.com/api/webhooks/vapi/

# ===== Meta Lead Ads (Phase 2E) =====
META_MODE=mock
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=
META_PAGE_ACCESS_TOKEN=
META_GRAPH_API_VERSION=v20.0
META_WEBHOOK_SECRET=

# ===== WhatsApp Cloud (Phase 5A) =====
# Switch to `meta_cloud` only when ALL Meta WABA credentials are filled.
# `baileys_dev` refuses to load when DEBUG=false unless
# WHATSAPP_DEV_PROVIDER_ENABLED=true is also set — keep both off in prod.
WHATSAPP_PROVIDER=mock
META_WA_PHONE_NUMBER_ID=
META_WA_BUSINESS_ACCOUNT_ID=
META_WA_ACCESS_TOKEN=
META_WA_VERIFY_TOKEN=
META_WA_APP_SECRET=
META_WA_API_VERSION=v20.0
WHATSAPP_WEBHOOK_SECRET=
WHATSAPP_DEV_PROVIDER_ENABLED=false
WHATSAPP_WEBHOOK_REPLAY_WINDOW_SECONDS=300

# ===== Phase 5C — WhatsApp AI Chat Sales Agent =====
# Default OFF. Flip to true ONLY after the WhatsApp team has confirmed
# the OpenAI key is configured AND a controlled set of test numbers has
# verified the conversation flow. Backend gates (consent + Claim Vault +
# matrix + safety + rate limits) still apply on every send regardless.
WHATSAPP_AI_AUTO_REPLY_ENABLED=false
WHATSAPP_AI_AUTO_REPLY_CONFIDENCE_THRESHOLD=0.75
WHATSAPP_AI_MAX_TURNS_PER_CONVERSATION_PER_HOUR=10
WHATSAPP_AI_MAX_MESSAGES_PER_CUSTOMER_PER_DAY=30

# ===== Phase 5D — Chat-to-Call Handoff + Lifecycle Automation =====
# Both default OFF. Production rollout sequence:
#   1) Mock first (verify the AI Chat Agent in mock mode end-to-end).
#   2) OpenAI test on a single test number.
#   3) Limited live Meta with WHATSAPP_LIVE_META_LIMITED_TEST_MODE=true
#      and exactly one number in WHATSAPP_LIVE_META_ALLOWED_TEST_NUMBERS.
#   4) Flip WHATSAPP_AI_AUTO_REPLY_ENABLED=true.
#   5) Flip WHATSAPP_CALL_HANDOFF_ENABLED=true after verifying Vapi.
#   6) Flip WHATSAPP_LIFECYCLE_AUTOMATION_ENABLED=true.
WHATSAPP_CALL_HANDOFF_ENABLED=false
WHATSAPP_LIFECYCLE_AUTOMATION_ENABLED=false
WHATSAPP_LIVE_META_LIMITED_TEST_MODE=true
WHATSAPP_LIVE_META_ALLOWED_TEST_NUMBERS=

# ===== Phase 5E — Rescue Discount + Day-20 Reorder + Default Claims =====
# All defaults OFF / SAFE. Production rollout extends the Phase 5D path:
#   7) Run `python manage.py seed_default_claims` (idempotent, demo only)
#      so the eight current categories have at least demo Claim Vault
#      coverage. Replace each demo seed with a doctor-approved claim
#      before flipping rescue / lifecycle to live mode.
#   8) Flip WHATSAPP_RESCUE_DISCOUNT_ENABLED=true (confirmation +
#      delivery rescue offers via the WhatsApp AI agent).
#   9) Flip WHATSAPP_RTO_RESCUE_DISCOUNT_ENABLED=true after 3+ days of
#      soak; this also unlocks AI-Call rescue offers on RTO refusal.
#   10) Flip WHATSAPP_REORDER_DAY20_ENABLED=true and add a daily
#       Celery beat / cron for `python manage.py run_reorder_day20_sweep`.
WHATSAPP_RESCUE_DISCOUNT_ENABLED=false
WHATSAPP_RTO_RESCUE_DISCOUNT_ENABLED=false
WHATSAPP_REORDER_DAY20_ENABLED=false
DEFAULT_CLAIMS_SEED_DEMO_ONLY=true

# ===== Frontend build-time =====
# Vite bakes these into the static bundle — they ship to every browser.
# Same-origin defaults so prod traffic stays inside ai.nirogidhara.com.
VITE_API_BASE_URL=/api
VITE_WS_BASE_URL=
