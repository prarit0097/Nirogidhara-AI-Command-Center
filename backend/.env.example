# Copy to .env and edit. Never commit .env.
DJANGO_SECRET_KEY=dev-only-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# SQLite by default. For Postgres set:
# DATABASE_URL=postgres://nirogidhara:nirogidhara@localhost:5432/nirogidhara
DATABASE_URL=sqlite:///db.sqlite3

# Frontend dev origin
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# JWT
JWT_SIGNING_KEY=dev-only-change-me-jwt

# ----- Razorpay (Phase 2B) -----
# RAZORPAY_MODE controls which client adapter is used:
#   mock — deterministic fake link, no network. Default for local dev.
#   test — real Razorpay test API (sandbox). Requires test keys.
#   live — real Razorpay production API. NEVER set this in dev/.env.example.
RAZORPAY_MODE=mock
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_CALLBACK_URL=

# ----- Delhivery (Phase 2C) -----
# DELHIVERY_MODE controls which client adapter is used:
#   mock — deterministic fake AWB ("DLH<8 digits>"), no network. Default for
#          local dev — keep this until you have real Delhivery credentials.
#   test — Delhivery staging API. Requires a real test token + a pickup
#          location registered with Delhivery.
#   live — Delhivery production. Never set this in dev/.env.example.
DELHIVERY_MODE=mock
DELHIVERY_API_BASE_URL=
DELHIVERY_API_TOKEN=
DELHIVERY_PICKUP_LOCATION=
DELHIVERY_RETURN_ADDRESS=
DELHIVERY_DEFAULT_PACKAGE_WEIGHT_GRAMS=500
DELHIVERY_WEBHOOK_SECRET=

# ----- Vapi (Phase 2D) -----
# VAPI_MODE controls which client adapter is used:
#   mock — deterministic fake call id (no network). Default for local dev.
#   test — Vapi staging. Requires a real test key + sandbox assistant +
#          phone-number id.
#   live — Vapi production. Never set this in dev/.env.example.
#
# COMPLIANCE HARD STOP: the Vapi assistant prompt must pull only from
# apps.compliance.Claim. Never inject free-style medical text.
VAPI_MODE=mock
VAPI_API_BASE_URL=
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=
VAPI_WEBHOOK_SECRET=
VAPI_DEFAULT_LANGUAGE=hi-IN
VAPI_CALLBACK_URL=

# ----- AI provider (Phase 3+ scaffolding) -----
# AI_PROVIDER picks which adapter the future agents layer dispatches through.
# Today no LLM call happens — this is just env scaffolding so Phase 3 can
# wire in OpenAI / Anthropic / Grok / etc. without touching settings again.
#
# COMPLIANCE HARD STOP (Master Blueprint §26 #4):
#   AI must speak ONLY from apps.compliance.Claim (Approved Claim Vault).
#   No free-style medical claims. Every prompt MUST inject the relevant
#   Claim entries before reaching the model. CAIO never executes.
#
# Supported values: disabled | openai | anthropic | grok
AI_PROVIDER=disabled
AI_MODEL=
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=2000
AI_REQUEST_TIMEOUT_SECONDS=30

# Per-provider keys. Only the key matching AI_PROVIDER is read at request
# time. Never logged. Never sent to the frontend.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_ORG_ID=

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

GROK_API_KEY=
GROK_BASE_URL=
