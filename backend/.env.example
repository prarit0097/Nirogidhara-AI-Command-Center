# Copy to .env and edit. Never commit .env.
DJANGO_SECRET_KEY=dev-only-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
# Optional. Defaults to Asia/Kolkata when unset (matches CELERY_TIMEZONE).
DJANGO_TIME_ZONE=Asia/Kolkata

# SQLite by default. For Postgres set:
# DATABASE_URL=postgres://nirogidhara:nirogidhara@localhost:5432/nirogidhara
DATABASE_URL=sqlite:///db.sqlite3

# Frontend dev origin
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# JWT
JWT_SIGNING_KEY=dev-only-change-me-jwt

# ----- Razorpay (Phase 2B) -----
# RAZORPAY_MODE controls which client adapter is used:
#   mock — deterministic fake link, no network. Default for local dev.
#   test — real Razorpay test API (sandbox). Requires test keys.
#   live — real Razorpay production API. NEVER set this in dev/.env.example.
RAZORPAY_MODE=mock
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_CALLBACK_URL=

# ----- Delhivery (Phase 2C) -----
# DELHIVERY_MODE controls which client adapter is used:
#   mock — deterministic fake AWB ("DLH<8 digits>"), no network. Default for
#          local dev — keep this until you have real Delhivery credentials.
#   test — Delhivery staging API. Requires a real test token + a pickup
#          location registered with Delhivery.
#   live — Delhivery production. Never set this in dev/.env.example.
DELHIVERY_MODE=mock
DELHIVERY_API_BASE_URL=
DELHIVERY_API_TOKEN=
DELHIVERY_PICKUP_LOCATION=
DELHIVERY_RETURN_ADDRESS=
DELHIVERY_DEFAULT_PACKAGE_WEIGHT_GRAMS=500
DELHIVERY_WEBHOOK_SECRET=

# ----- Vapi (Phase 2D) -----
# VAPI_MODE controls which client adapter is used:
#   mock — deterministic fake call id (no network). Default for local dev.
#   test — Vapi staging. Requires a real test key + sandbox assistant +
#          phone-number id.
#   live — Vapi production. Never set this in dev/.env.example.
#
# COMPLIANCE HARD STOP: the Vapi assistant prompt must pull only from
# apps.compliance.Claim. Never inject free-style medical text.
VAPI_MODE=mock
VAPI_API_BASE_URL=
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=
VAPI_WEBHOOK_SECRET=
VAPI_DEFAULT_LANGUAGE=hi-IN
VAPI_CALLBACK_URL=

# ----- Meta Lead Ads (Phase 2E) -----
# META_MODE controls which client adapter is used:
#   mock — parse the inbound webhook body directly. No network. Default for
#          local dev — Meta deliveries already include field_data.
#   test — call Meta Graph API to expand each leadgen_id. Requires real
#          test app credentials + page access token.
#   live — Meta production. Never set this in dev/.env.example.
META_MODE=mock
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=
META_PAGE_ACCESS_TOKEN=
META_GRAPH_API_VERSION=v20.0
META_WEBHOOK_SECRET=

# ----- AI provider (Phase 3+ scaffolding) -----
# AI_PROVIDER picks which adapter the future agents layer dispatches through.
# Today no LLM call happens — this is just env scaffolding so Phase 3 can
# wire in OpenAI / Anthropic / Grok / etc. without touching settings again.
#
# COMPLIANCE HARD STOP (Master Blueprint §26 #4):
#   AI must speak ONLY from apps.compliance.Claim (Approved Claim Vault).
#   No free-style medical claims. Every prompt MUST inject the relevant
#   Claim entries before reaching the model. CAIO never executes.
#
# Supported values: disabled | openai | anthropic | grok
AI_PROVIDER=disabled
AI_MODEL=
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=2000
AI_REQUEST_TIMEOUT_SECONDS=30

# Per-provider keys. Only the key matching AI_PROVIDER is read at request
# time. Never logged. Never sent to the frontend.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_ORG_ID=

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

GROK_API_KEY=
GROK_BASE_URL=
# Optional Grok model override consumed by the AI fallback chain. Empty
# string falls back to AI_MODEL.
GROK_MODEL=

# ----- Phase 3C — Celery scheduler + AI fallback + cost tracking -----
# Local development NEVER needs Redis to be running — `CELERY_TASK_ALWAYS_EAGER=true`
# (the default) makes `.delay()` run synchronously. Spin up Redis only when
# you start a worker:
#   docker compose -f docker-compose.dev.yml up -d redis
#   celery -A config worker -B --loglevel=info
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_ALWAYS_EAGER=false

# Daily CEO + CAIO briefing schedule (IST by default). Hours / minutes are
# 0–23 / 0–59 — anything else falls back to the locked defaults (09:00 + 18:00).
AI_DAILY_BRIEFING_MORNING_HOUR=9
AI_DAILY_BRIEFING_MORNING_MINUTE=0
AI_DAILY_BRIEFING_EVENING_HOUR=18
AI_DAILY_BRIEFING_EVENING_MINUTE=0
AI_TIMEZONE=Asia/Kolkata

# Provider fallback chain. The dispatcher walks this list left → right; the
# first provider whose adapter returns ``success`` wins. Empty list collapses
# to a single-provider chain made of just AI_PROVIDER. Compliance refusals
# (ClaimVaultMissing) NEVER trigger a fallback — they fail closed.
AI_PROVIDER_FALLBACKS=openai,anthropic

# Per-provider model overrides used by the fallback chain. The OpenAI
# attempt uses OPENAI_FALLBACK_MODEL (or AI_MODEL); the Anthropic fallback
# uses ANTHROPIC_MODEL. Provider pricing is stored model-wise in
# apps/integrations/ai/pricing.py — review periodically against the
# official provider pricing pages.
AI_MODEL=gpt-5.1
OPENAI_FALLBACK_MODEL=gpt-5.1
ANTHROPIC_MODEL=claude-sonnet-4-6

# Phase 3D — sandbox boot-time default. The live toggle lives in the
# SandboxState singleton (PATCH /api/ai/sandbox/status/). When sandbox
# is enabled, AgentRuns still execute but never refresh CeoBriefing or
# any business-state row. CAIO is read-only regardless.
AI_SANDBOX_MODE=false

# ----- Phase 5A — WhatsApp (Meta Cloud API) -----
# WHATSAPP_PROVIDER picks which adapter the send pipeline dispatches through:
#   mock        — deterministic mock (no network). Default for local dev / CI.
#                 Mints `wamid.MOCK_<n>` provider message ids.
#   meta_cloud  — production target. Calls
#                 https://graph.facebook.com/{version}/{phone_number_id}/messages.
#                 HMAC-SHA256 webhook verification via META_WA_APP_SECRET.
#   baileys_dev — explicit dev-only stub. Refuses to load when
#                 DJANGO_DEBUG=False AND WHATSAPP_DEV_PROVIDER_ENABLED!=true.
#
# COMPLIANCE HARD STOP (Master Blueprint §26 / Phase 5A-1):
#   Every WhatsApp send must be consent + approved-template + Claim-Vault
#   gated server-side. Failed sends never mutate Order / Payment / Shipment.
#   CAIO never sends customer messages.
WHATSAPP_PROVIDER=mock
META_WA_PHONE_NUMBER_ID=
META_WA_BUSINESS_ACCOUNT_ID=
META_WA_ACCESS_TOKEN=
META_WA_VERIFY_TOKEN=
META_WA_APP_SECRET=
META_WA_API_VERSION=v20.0
# Optional alternate webhook secret. When set, the webhook view prefers this
# value; otherwise it falls back to META_WA_APP_SECRET.
WHATSAPP_WEBHOOK_SECRET=
# Master kill switch for the dev-only Baileys provider. Production must keep
# this `false` — the settings layer hard-rejects `baileys_dev` when DEBUG=False
# AND this flag is not `true`.
WHATSAPP_DEV_PROVIDER_ENABLED=false
# Webhook replay window in seconds. Requests carrying a timestamp header older
# than this are rejected.
WHATSAPP_WEBHOOK_REPLAY_WINDOW_SECONDS=300

# ----- Phase 5C — WhatsApp AI Chat Sales Agent -----
# Auto-reply behaviour. Defaults are SAFE (off) so a fresh deploy never
# auto-replies to a customer until ops explicitly opt in. Production flips
# WHATSAPP_AI_AUTO_REPLY_ENABLED=true once the team has verified flow + the
# OpenAI key is configured. Backend gates (consent + Claim Vault + matrix +
# safety + rate limits) still apply on EVERY send regardless of this flag.
WHATSAPP_AI_AUTO_REPLY_ENABLED=false
WHATSAPP_AI_AUTO_REPLY_CONFIDENCE_THRESHOLD=0.75
WHATSAPP_AI_MAX_TURNS_PER_CONVERSATION_PER_HOUR=10
WHATSAPP_AI_MAX_MESSAGES_PER_CUSTOMER_PER_DAY=30

# ----- Phase 5D — Chat-to-Call Handoff + Lifecycle Automation -----
# Direct WhatsApp → Vapi handoff. Defaults OFF so a fresh deploy does not
# auto-dial customers until ops have verified the Vapi assistant config
# end-to-end (mock first, then OpenAI test, then limited live Meta).
# Backend safety reasons (medical_emergency / side_effect_complaint /
# legal_threat) still record a handoff row but never auto-dial sales.
WHATSAPP_CALL_HANDOFF_ENABLED=false

# Lifecycle template automation. Defaults OFF — when enabled, business
# events (order moved to confirmation, payment link created, shipment
# out for delivery / NDR / RTO) trigger approved-template sends through
# the Phase 5A pipeline. All consent / Claim Vault / approval matrix /
# CAIO gates remain in force.
WHATSAPP_LIFECYCLE_AUTOMATION_ENABLED=false

# Limited live Meta test mode — when WHATSAPP_PROVIDER=meta_cloud and
# this flag is true, the service layer must refuse to send to any
# number not in WHATSAPP_LIVE_META_ALLOWED_TEST_NUMBERS. Bridge between
# mock+OpenAI verification and a full production rollout.
WHATSAPP_LIVE_META_LIMITED_TEST_MODE=true
WHATSAPP_LIVE_META_ALLOWED_TEST_NUMBERS=

# ----- Phase 4A — Real-time AuditEvent WebSockets via Django Channels -----
# Local dev / pytest default to the in-memory channel layer so neither
# Redis nor the daphne ASGI runner is required for the test suite. To
# stream live AuditEvent updates with persistence across worker
# processes (the production target), point Channels at Redis:
#   CHANNEL_LAYER_BACKEND=redis
#   CHANNEL_REDIS_URL=redis://localhost:6379/2
# (Index 2 is reserved for Channels — Celery uses 0/1.) The frontend
# can override the WebSocket origin via VITE_WS_BASE_URL; otherwise it
# derives the URL from VITE_API_BASE_URL.
CHANNEL_LAYER_BACKEND=memory
CHANNEL_REDIS_URL=redis://localhost:6379/2
