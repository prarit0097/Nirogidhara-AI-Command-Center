# Frontend env. Never commit a populated copy as `.env`.
# All vars must be prefixed with VITE_ to be exposed to the Vite client bundle
# (see https://vite.dev/guide/env-and-mode.html).

# REST API base URL. The frontend service layer prepends this to every path
# (e.g. `/dashboard/metrics/`).
VITE_API_BASE_URL=http://localhost:8000/api

# Optional WebSocket origin override for the Phase 4A live AuditEvent stream.
# When unset, `frontend/src/services/realtime.ts` derives the WebSocket URL
# from VITE_API_BASE_URL by swapping http/https for ws/wss. Set this only
# when the WebSocket server lives on a different host than the REST API.
VITE_WS_BASE_URL=
